body {
  margin: 0;
  font-family: "Segoe UI", sans-serif;
  display: flex;
  height: 100vh;
  background: #f5f5f5;
}

#container {
  display: flex;
  width: 100%;
}

#sidebar {
  width: 280px;
  overflow-y: auto;
  background: #1b1f23;
  color: #c9d1d9;
  padding: 15px;
  box-sizing: border-box;
}

#sidebar h3 {
  margin-top: 20px;
  margin-bottom: 5px;
  font-size: 16px;
  cursor: default;
  color: #58a6ff;
}

.file-list {
  list-style: none;
  padding-left: 15px;
}

.file-list li {
  margin: 4px 0;
}

.file-list a {
  color: #c9d1d9;
  text-decoration: none;
}

.file-list a:hover {
  color: #58a6ff;
  text-decoration: underline;
}

#content {
  flex-grow: 1;
  overflow-y: auto;
  padding: 25px;
  background: #ffffff;
  box-sizing: border-box;
}

h1, h2, h3, h4, h5, h6 {
  color: #1f2328;
}

pre, code {
  background: #f0f0f0;
  padding: 3px 5px;
  border-radius: 4px;
}

a {
  color: #0366d6;
}