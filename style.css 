body {
  font-family: sans-serif;
  background-color: #f0f9ff;
  color: #0a3d62;
  margin: 2em;
}

h1, h2, h3 {
  color: #0d6efd;
}

nav ul {
  list-style: none;
  padding: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 1em;
}

nav a {
  text-decoration: none;
  color: #0d6efd;
  font-weight: bold;
  padding: 0.3em 0.6em;
  border-radius: 4px;
  transition: background-color 0.2s;
}

nav a:hover {
  background-color: #cce5ff;
}

#content {
  margin-top: 2em;
  line-height: 1.6;
}