body {
  display: flex;
  margin: 0;
  font-family: sans-serif;
}

#sidebar {
  width: 250px;
  background: #f0f0f0;
  padding: 1rem;
  height: 100vh;
  overflow-y: auto;
}

#sidebar .folder {
  font-weight: bold;
  margin-top: 1rem;
}

#sidebar ul {
  list-style: none;
  padding-left: 1rem;
}

#sidebar a {
  text-decoration: none;
  color: #333;
}

#sidebar a:hover {
  text-decoration: underline;
}

#content {
  flex: 1;
  padding: 2rem;
  overflow-x: auto;
  background: #fff;
}