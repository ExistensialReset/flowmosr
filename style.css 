body {
  font-family: sans-serif;
  background-color: #f0f9ff;
  color: #0a3d62;
  margin: 2em;
}

h1, h2, h3 {
  color: #0d6efd;
}

nav ul {
  list-style: none;
  padding: 0;
  display: flex;
  gap: 1em;
}

nav a {
  text-decoration: none;
  color: #0d6efd;
  font-weight: bold;
}

nav a:hover {
  text-decoration: underline;
}

#content {
  margin-top: 2em;
  line-height: 1.6;
}